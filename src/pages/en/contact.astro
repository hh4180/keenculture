---
import BaseLayout from '../../layouts/BaseLayout.astro';

const contactMethods = [
  {
    icon: '📧',
    title: 'Email',
    value: 'info@keencreative.jp',
    href: 'mailto:info@keencreative.jp',
    description: 'Reply within 24 business hours',
  },
  {
    icon: '💬',
    title: 'WeChat',
    value: 'KeenCultureJP',
    href: '#',
    description: 'Add us on WeChat for direct communication',
  },
  {
    icon: '📍',
    title: 'Address',
    value: '2-3-15 Innai, TOP Nishi-Funabashi Dai-1 #102, Funabashi, Chiba 273-0039, Japan',
    href: '#',
    description: 'Founded in December 2023',
  },
];

const inquiryTypes = [
  'Eyewear Wholesale Cooperation',
  'Tools Procurement Inquiry',
  'Third-party Repair Collaboration',
  'Logistics Plan',
  'ITBEGIN Channel Cooperation',
  'Others',
];
---

<BaseLayout
  title="Contact Us | KeenCulture"
  description="Contact KeenCulture for Japanese frame sourcing, tool supply, and third-party repair collaboration services."
>
  <section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 py-20 lg:py-28">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-amber-400 font-medium mb-4 tracking-wide">CONTACT US</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Let’s Work Together
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          Whether you are a retailer, wholesaler, or need Japan-based tools procurement and repair collaboration,
          feel free to contact us. As a bridge between Japanese craftsmanship and overseas markets,
          our team will respond within 24 business hours.
        </p>
      </div>
    </div>
    <div class="absolute top-1/2 right-0 translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl"></div>
  </section>

  <section class="py-20 lg:py-28 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-slate-900 mb-8">Send an Inquiry</h2>

          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-2">
                  Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-slate-700 mb-2">
                  Company Name
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="Company or store name"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-2">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="your@email.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">
                  Phone / WeChat
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="Phone number or WeChat ID"
                />
              </div>
            </div>

            <div>
              <label for="type" class="block text-sm font-medium text-slate-700 mb-2">
                Inquiry Type <span class="text-red-500">*</span>
              </label>
              <select
                id="type"
                name="type"
                required
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all bg-white"
              >
                <option value="">Please select inquiry type</option>
                {inquiryTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-2">
                Message <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows={5}
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all resize-none"
                placeholder="Please describe your requirements in detail..."
              ></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full sm:w-auto px-8 py-4 text-base font-medium text-slate-900 bg-amber-400 rounded-lg hover:bg-amber-300 transition-all hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
            >
              Submit Inquiry
            </button>

            <div id="form-status" class="hidden mt-4 p-4 rounded-lg"></div>
          </form>
        </div>

        <div class="lg:col-span-1">
          <h2 class="text-2xl font-bold text-slate-900 mb-8">Contact Information</h2>

          <div class="space-y-6">
            {contactMethods.map((method) => (
              <div class="p-6 bg-slate-50 rounded-xl">
                <div class="flex items-start gap-4">
                  <span class="text-2xl">{method.icon}</span>
                  <div>
                    <h3 class="font-semibold text-slate-900">{method.title}</h3>
                    {method.href.startsWith('mailto:') ? (
                      <a href={method.href} class="text-amber-600 hover:text-amber-700 transition-colors">
                        {method.value}
                      </a>
                    ) : (
                      <p class="text-slate-600">{method.value}</p>
                    )}
                    <p class="text-sm text-slate-400 mt-1">{method.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 p-6 bg-amber-50 rounded-xl border border-amber-100">
            <h3 class="font-semibold text-slate-900 mb-2">Business Hours</h3>
            <p class="text-slate-600 text-sm">
              Monday to Friday: 9:00 - 18:00 (JST)<br/>
              Weekends and Japanese public holidays closed
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-white mb-2">24h</div>
          <div class="text-slate-400">Business-day response</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white mb-2">CN/JP Bilingual</div>
          <div class="text-slate-400">Smooth communication</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white mb-2">Professional Team</div>
          <div class="text-slate-400">Deep optical industry focus</div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const statusDiv = document.getElementById('form-status') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      statusDiv.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (response.ok && data.success) {
          statusDiv.className = 'mt-4 p-4 rounded-lg bg-green-50 text-green-800 border border-green-200';
          statusDiv.textContent = data.message || 'Submitted successfully!';
          statusDiv.classList.remove('hidden');
          form.reset();
        } else {
          statusDiv.className = 'mt-4 p-4 rounded-lg bg-red-50 text-red-800 border border-red-200';
          statusDiv.textContent = data.error || 'Submission failed. Please try again.';
          statusDiv.classList.remove('hidden');
        }
      } catch {
        statusDiv.className = 'mt-4 p-4 rounded-lg bg-red-50 text-red-800 border border-red-200';
        statusDiv.textContent = 'Network error. Please check your connection and try again.';
        statusDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Inquiry';
      }
    });
  </script>
</BaseLayout>
