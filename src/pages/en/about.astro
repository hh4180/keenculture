---
import BaseLayout from '../../layouts/BaseLayout.astro';

const timeline = [
  { year: '2023.12', title: 'Company Founded', description: 'KeenCulture was established in Funabashi, Chiba, Japan.' },
  { year: '2024', title: 'Agency Discussion Phase', description: 'Continued partnership discussions with TOPTECH.OPT Co., LTD on overseas channel agency for ITBEGIN frames.' },
  { year: '2025', title: 'Formal Operations Start', description: 'Officially launched eyewear and tool procurement services, together with premium eyewear repair collaboration.' },
  { year: '2026.01', title: 'Official Agency Signing', description: 'Completed the formal signing with TOPTECH.OPT Co., LTD for ITBEGIN overseas channel agency.' },
];

const values = [
  {
    icon: '🎯',
    title: 'Craftsmanship First',
    description: 'We rigorously select Japanese materials and craftsmanship to deliver high-value frames tailored for Asian facial profiles.',
  },
  {
    icon: '🤝',
    title: 'Authenticity & Authorization',
    description: 'We maintain authentic, authorized supply and stable pricing to ensure reliable procurement and traceable after-sales support.',
  },
  {
    icon: '⚡',
    title: 'One-stop Coordination',
    description: 'From products and tools to repair collaboration and cross-border delivery, we reduce communication and execution costs.',
  },
  {
    icon: '🌐',
    title: 'Bridge Value',
    description: 'We connect overseas partners with Japanese factories to solve complex technical problems that are difficult to handle locally.',
  },
];
---

<BaseLayout
  title="About Us | KeenCulture"
  description="Founded in December 2023 in Funabashi, Chiba, KeenCulture provides eyewear products, tools, and third-party repair collaboration services for APAC markets."
>
  <section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 py-20 lg:py-28">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-amber-400 font-medium mb-4 tracking-wide">ABOUT US</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          Bridging Japan and APAC<br/>Optical Markets
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          KeenCulture was founded in December 2023 in Funabashi, Chiba, Japan.
          We are committed to becoming a leading integrated eyewear service provider in Asia by connecting Japanese craftsmanship with overseas demand.
        </p>
      </div>
    </div>
    <div class="absolute top-1/2 right-0 translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl"></div>
  </section>

  <section class="py-20 lg:py-28 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-amber-600 font-medium mb-2">OUR STORY</p>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">
            From Funabashi to APAC
          </h2>
          <div class="space-y-4 text-slate-600 leading-relaxed">
            <p>
              As a bridge between Japanese craftsmanship and overseas markets, we aim to become a leading eyewear service provider in Asia.
              With strong Japan-based supply-chain advantages, we provide one-stop solutions for clients in Mainland China, Hong Kong, and Southeast Asia.
            </p>
            <p>
              We have deep local eyewear industry networks in Japan and focus on sourcing high-quality artisan-made frames and designer brands.
              Through strict material and craftsmanship standards, we provide high value-added products designed for Asian facial profiles.
            </p>
            <p>
              Beyond eyewear products, we also supply Japanese optical tools and equipment for overseas stores and processing centers,
              including adjustment tools, welding equipment, screw components, and cleaning consumables, while advancing third-party collaboration with Japanese repair factories.
            </p>
            <p>
              In 2024, we were in ongoing agency discussions with TOPTECH.OPT Co., LTD for ITBEGIN overseas channels,
              and completed the official signing in January 2026. Since 2025, we have formally operated eyewear and tool procurement,
              while advancing premium eyewear repair collaboration to provide more complete after-sales support for partners.
            </p>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-[4/3] bg-gradient-to-br from-slate-100 to-slate-200 rounded-2xl flex items-center justify-center">
            <div class="text-center p-8">
              <div class="text-6xl mb-4">🏢</div>
              <p class="text-xl font-bold text-slate-700">Funabashi, Chiba</p>
              <p class="text-slate-500">Japan</p>
            </div>
          </div>
          <div class="absolute -bottom-4 -left-4 w-24 h-24 bg-amber-400/30 rounded-full blur-xl"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-slate-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-amber-600 font-medium mb-2">OUR VALUES</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          Core Values
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {values.map((value) => (
          <div class="p-6 bg-white rounded-2xl border border-slate-100">
            <div class="text-4xl mb-4">{value.icon}</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-2">{value.title}</h3>
            <p class="text-slate-600">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <p class="text-amber-600 font-medium mb-2">MILESTONES</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
          Development Timeline
        </h2>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-amber-200 md:left-1/2 md:-translate-x-1/2"></div>

          <div class="space-y-12">
            {timeline.map((item, index) => (
              <div class={`relative flex items-center gap-8 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
                <div class="hidden md:block md:w-1/2"></div>
                <div class="absolute left-4 w-3 h-3 bg-amber-400 rounded-full md:left-1/2 md:-translate-x-1/2 ring-4 ring-amber-100"></div>
                <div class="ml-12 md:ml-0 md:w-1/2 p-6 bg-slate-50 rounded-xl">
                  <span class="text-amber-600 font-bold text-lg">{item.year}</span>
                  <h3 class="text-xl font-semibold text-slate-900 mt-1">{item.title}</h3>
                  <p class="text-slate-600 mt-2">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28 bg-gradient-to-br from-slate-900 to-slate-800">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
        Work With Us
      </h2>
      <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto">
        Whether you are a retailer, wholesaler, or looking for professional tools and repair support,
        we welcome your inquiry.
      </p>
      <a
        href="/en/contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-slate-900 bg-amber-400 rounded-lg hover:bg-amber-300 transition-all hover:scale-105"
      >
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
