---
import BaseLayout from '../../layouts/BaseLayout.astro';

const contactMethods = [
  {
    icon: '📧',
    title: '電子郵件',
    value: 'info@keen-culture.com',
    href: 'mailto:info@keen-culture.com',
    description: '工作日24小時內回覆',
  },
  {
    icon: '💬',
    title: '微信',
    value: 'KeenCultureJP',
    href: '#',
    description: '掃碼添加企業微信',
  },
  {
    icon: '📍',
    title: '地址',
    value: '〒273-0039 日本國千葉縣船橋市印內2丁目3番15號 TOP西船橋第一102號室',
    href: '#',
    description: 'Funabashi, Chiba, Japan · 成立於2023年12月',
  },
];

const inquiryTypes = [
  '眼鏡批發合作',
  '工具採購洽詢',
  '第三方維修協作',
  '物流方案',
  'ITBEGIN 渠道合作',
  '其他',
];
---

<BaseLayout
  title="聯絡我們 | KeenCulture"
  description="聯絡キンーカルチャー株式会社，洽詢日本鏡架採購、工具供應與第三方維修協作服務。"
>
  <section class="relative bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 py-20 lg:py-28">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-amber-400 font-medium mb-4 tracking-wide">CONTACT US</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-6">
          期待與您合作
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed">
          無論您是眼鏡零售商、批發商，或需日本工具採購與維修協作支援，歡迎隨時聯絡我們。
          作為連接日本工藝與海外市場的橋樑，我們的團隊將於工作日24小時內回覆。
        </p>
      </div>
    </div>
    <div class="absolute top-1/2 right-0 translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-amber-500/10 rounded-full blur-3xl"></div>
  </section>

  <section class="py-20 lg:py-28 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-slate-900 mb-8">發送洽詢</h2>

          <form id="contact-form" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-2">
                  姓名 <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="您的姓名"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-slate-700 mb-2">
                  公司名稱
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="公司或門店名稱"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-2">
                  電子郵件 <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="your@email.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-slate-700 mb-2">
                  電話/微信
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all"
                  placeholder="聯絡電話或微信號"
                />
              </div>
            </div>

            <div>
              <label for="type" class="block text-sm font-medium text-slate-700 mb-2">
                洽詢類型 <span class="text-red-500">*</span>
              </label>
              <select
                id="type"
                name="type"
                required
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all bg-white"
              >
                <option value="">請選擇洽詢類型</option>
                {inquiryTypes.map((type) => (
                  <option value={type}>{type}</option>
                ))}
              </select>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-2">
                洽詢內容 <span class="text-red-500">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows={5}
                class="w-full px-4 py-3 rounded-lg border border-slate-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-400/20 outline-none transition-all resize-none"
                placeholder="請詳細描述您的需求..."
              ></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full sm:w-auto px-8 py-4 text-base font-medium text-slate-900 bg-amber-400 rounded-lg hover:bg-amber-300 transition-all hover:scale-105 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
            >
              提交洽詢
            </button>

            <div id="form-status" class="hidden mt-4 p-4 rounded-lg"></div>
          </form>
        </div>

        <div class="lg:col-span-1">
          <h2 class="text-2xl font-bold text-slate-900 mb-8">聯絡方式</h2>

          <div class="space-y-6">
            {contactMethods.map((method) => (
              <div class="p-6 bg-slate-50 rounded-xl">
                <div class="flex items-start gap-4">
                  <span class="text-2xl">{method.icon}</span>
                  <div>
                    <h3 class="font-semibold text-slate-900">{method.title}</h3>
                    {method.href.startsWith('mailto:') ? (
                      <a href={method.href} class="text-amber-600 hover:text-amber-700 transition-colors">
                        {method.value}
                      </a>
                    ) : (
                      <p class="text-slate-600">{method.value}</p>
                    )}
                    <p class="text-sm text-slate-400 mt-1">{method.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 p-6 bg-amber-50 rounded-xl border border-amber-100">
            <h3 class="font-semibold text-slate-900 mb-2">工作時間</h3>
            <p class="text-slate-600 text-sm">
              週一至週五: 9:00 - 18:00 (日本時間)<br/>
              週六日及日本法定假日休息
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div>
          <div class="text-3xl font-bold text-white mb-2">24h</div>
          <div class="text-slate-400">工作日回覆</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white mb-2">中日雙語</div>
          <div class="text-slate-400">無障礙溝通</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-white mb-2">專業團隊</div>
          <div class="text-slate-400">深耕眼鏡產業</div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const statusDiv = document.getElementById('form-status') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      submitBtn.disabled = true;
      submitBtn.textContent = '提交中...';
      statusDiv.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (response.ok && data.success) {
          statusDiv.className = 'mt-4 p-4 rounded-lg bg-green-50 text-green-800 border border-green-200';
          statusDiv.textContent = data.message || '提交成功！';
          statusDiv.classList.remove('hidden');
          form.reset();
        } else {
          statusDiv.className = 'mt-4 p-4 rounded-lg bg-red-50 text-red-800 border border-red-200';
          statusDiv.textContent = data.error || '提交失敗，請重試';
          statusDiv.classList.remove('hidden');
        }
      } catch {
        statusDiv.className = 'mt-4 p-4 rounded-lg bg-red-50 text-red-800 border border-red-200';
        statusDiv.textContent = '網路錯誤，請檢查連線後重試';
        statusDiv.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = '提交洽詢';
      }
    });
  </script>
</BaseLayout>
